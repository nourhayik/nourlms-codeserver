# =============================================================================
# NourLMS Code Server — environment configuration
# =============================================================================
#
# Copy this file to `.env` (or `.env.local`) in the same directory you launch
# the server from. The server loads it automatically at startup. Real
# environment variables (e.g. systemd Environment=, docker run -e ...) ALWAYS
# win over values in `.env`, so this file is safe to commit a template of.
#
# Override the default search by setting NOURLMS_ENV_FILE to an absolute path
# before starting the server (e.g. NOURLMS_ENV_FILE=/etc/nourlms/server.env).
# =============================================================================


# --- Required: upstream NourLMS API ------------------------------------------
# Base URL the server proxies to for /nourlms-login, /nourlms-logout, and the
# /nourlms-api/* routes. Must end without a trailing slash. Use https in
# production.
NOURLMS_API_URL=http://nourlmsv3.local/api


# --- Where student workspaces live -------------------------------------------
# Absolute path to a directory the server can read/write. One subfolder per
# student is created on first login. Defaults to `<HOME>/nourlms-workspaces`.
# Pin this to a stable disk path in production (e.g. /var/lib/nourlms/workspaces).
# NOURLMS_WORKSPACES_DIR=/var/lib/nourlms/workspaces


# --- Network bind ------------------------------------------------------------
# Host and port the HTTP server listens on. Equivalent to --host / --port on
# the command line, and to VSCODE_SERVER_HOST / VSCODE_SERVER_PORT (which are
# set automatically from these aliases).
# NOURLMS_HOST=0.0.0.0
# NOURLMS_PORT=8000


# --- Optional: connection token ---------------------------------------------
# When set, all WebSocket connections must include this token. Equivalent to
# --connection-token. If unset and not provided on the CLI either, the server
# falls back to its default behavior (random token printed at startup).
# NOURLMS_CONNECTION_TOKEN=please-change-me-in-prod


# --- Optional: telemetry -----------------------------------------------------
# Set to "true" to disable VS Code crash reporter and telemetry uploads.
# NOURLMS_DISABLE_TELEMETRY=true


# --- Optional: AI assistant (server-side proxy) ------------------------------
# When set, admins can use the AI prompt feature in the new-question form to
# auto-fill all fields from a free-text description. The browser NEVER sees
# the key — calls go through the server-side /nourlms-ai/* proxy and the
# server adds Authorization + x-openclaw-scopes headers upstream. The proxy
# is admin-only (students get 404).
#
# The client posts to `/nourlms-ai/chat/completions` (matching the upstream
# OpenAI-compatible path); the server forwards to `${AI_API_BASE_URL}/chat/completions`.
#
# Default base URL: https://ai.nourlms.com/v1 (OpenAI-compatible).
# Default model:    `openclaw/default` (the gateway rejects `gpt-4o-mini` with
#                   HTTP 400). AI_API_MODEL overrides this server-side without
#                   rebuilding the workbench.
# Default scopes:   `operator.admin,operator.read,operator.write` — required by
#                   the OpenClaw gateway (HTTP 403 without it). AI_API_SCOPES
#                   lets you pin a narrower set if needed.
# AI_API_KEY=
# AI_API_BASE_URL=https://ai.nourlms.com/v1
# AI_API_MODEL=openclaw/default
# AI_API_SCOPES=operator.admin,operator.read,operator.write
